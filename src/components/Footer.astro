---
const basePath = "/HelloKostek";
const currentYear = new Date().getFullYear();
---

<footer class="bg-neutral-50 border-t border-neutral-200 pb-16 pt-20">
  <div class="max-w-[1600px] mx-auto px-6 md:px-12 lg:px-16 xl:px-20 2xl:px-6 3xl:px-0 grid grid-cols-1 md:grid-cols-12 gap-12">
    <!-- Column 1 - Brand Summary -->
    <div class="md:col-span-5 space-y-2">
      <div class="w-full max-w-[560px] h-44 md:h-64 overflow-hidden flex items-center justify-start py-1">
        <img
          src="https://hellokostek.pl/wp-content/uploads/2021/05/logo-animation-30fps-v-2.gif"
          alt="hellokostek"
          referrerpolicy="no-referrer"
          class="max-w-full max-h-full object-contain mix-blend-multiply"
        />
      </div>
      <p class="font-sans text-xs sm:text-sm text-stone-500 max-w-md leading-relaxed">
        Pracownia Artystyczna <strong class="font-bold">hellokostek</strong> to miejsce, gdzie tradycyjne malarstwo olejne, rysunek i sztuka tworzona na podstawie zdjęć łączą się w harmonijną całość. Tworzę z myślą o tych, którzy cenią ciepło, miłość i rodzinne pamiątki.
      </p>
    </div>

    <!-- Column 2 - Oferta & Odkryj (Stacked) -->
    <div class="md:col-span-3 space-y-10 font-sans text-xs sm:text-sm">
      <!-- Oferta -->
      <div class="space-y-4">
        <span class="font-mono text-xs uppercase text-stone-400 tracking-wider block font-bold">Oferta</span>
        <ul class="space-y-2 text-stone-600">
          <li>
            <a 
              href={`${basePath}/`} 
              class="hover:text-magenta-accent transition-colors cursor-pointer text-left block"
            >
              Portrety ze zdjęcia na zamówienie
            </a>
          </li>
          <li>
            <a 
              href={`${basePath}/sklep`} 
              class="hover:text-magenta-accent transition-colors cursor-pointer text-left block"
            >
              Sklep z gotowymi dziełami
            </a>
          </li>
          <li>
            <a 
              href={`${basePath}/galeria`} 
              class="hover:text-magenta-accent transition-colors cursor-pointer text-left block"
            >
              Galeria portretów
            </a>
          </li>
        </ul>
      </div>

      <!-- Odkryj -->
      <div class="space-y-4">
        <span class="font-mono text-xs uppercase text-stone-400 tracking-wider block font-bold">Odkryj</span>
        <ul class="space-y-2 text-stone-600">
          <li>
            <a 
              href={`${basePath}/o-mnie`} 
              class="hover:text-magenta-accent transition-colors cursor-pointer text-left block"
            >
              O mnie
            </a>
          </li>
          <li>
            <a 
              href={`${basePath}/kontakt`} 
              class="hover:text-magenta-accent transition-colors cursor-pointer text-left block"
            >
              Kontakt
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Column 3 - Direct contact block details -->
    <div class="md:col-span-4 space-y-4 font-sans text-xs sm:text-sm">
      <span class="font-mono text-xs uppercase text-stone-400 tracking-wider block font-bold">Kontakt</span>
      <p class="text-stone-600 leading-normal">
        Masz pytania? Chcesz skonsultować kompozycję?<br />
        <a href="mailto:kontakt@hellokostek.pl" class="font-bold text-off-black hover:text-magenta-accent transition-colors block mt-2">
          kontakt@hellokostek.pl
        </a>
        <a href="tel:+48662707153" class="font-bold text-off-black hover:text-magenta-accent transition-colors block mt-1">
          tel. 662 707 153
        </a>
      </p>
      <div class="flex gap-3 pt-1">
        <a
          href="https://www.instagram.com/hellokostek/"
          target="_blank"
          rel="noopener noreferrer"
          class="w-8 h-8 rounded-full bg-neutral-100 flex items-center justify-center text-stone-650 hover:bg-magenta-accent hover:text-white transition-all duration-300"
          aria-label="Instagram"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.51"></line></svg>
        </a>
        <a
          href="https://www.facebook.com/hellokostek/"
          target="_blank"
          rel="noopener noreferrer"
          class="w-8 h-8 rounded-full bg-neutral-100 flex items-center justify-center text-stone-650 hover:bg-[#1877F2] hover:text-white transition-all duration-300"
          aria-label="Facebook"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
        </a>
      </div>
      <div class="text-xs font-mono text-stone-400 mt-8 pt-4 border-t border-stone-200/40 space-y-1">
        <div class="font-bold text-xs uppercase tracking-wider text-stone-400">hellokostek Maciej Kosteczka</div>
        <div class="flex gap-2 font-bold">
          <span>NIP: 625-236-36-56</span> • <span>REGON: 527158196</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Rights Bar -->
  <div class="max-w-[1600px] mx-auto px-6 md:px-12 lg:px-16 xl:px-20 2xl:px-6 3xl:px-0 border-t border-stone-150 mt-12 pt-8 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-stone-400 font-sans text-center md:text-left">
    <!-- Left: Realization -->
    <div class="order-3 md:order-1">
      <span>Realizacja: <a href="https://webisko.pl/" target="_blank" rel="noopener noreferrer" class="font-bold hover:text-magenta-accent transition-colors text-stone-500">Webisko.pl</a></span>
    </div>

    <!-- Middle: Copyright -->
    <div class="order-1 md:order-2">
      <p>© {currentYear} hellokostek.pl. Wszelkie prawa zastrzeżone. Rękodzieło i malarstwo artystyczne.</p>
    </div>

    <!-- Right: Formal Links -->
    <div class="order-2 md:order-3 flex gap-4">
      <a 
        href={`${basePath}/polityka-prywatnosci`} 
        class="hover:text-magenta-accent transition-colors cursor-pointer block"
      >
        Polityka prywatności i plików cookies
      </a>
      <span>•</span>
      <a 
        href={`${basePath}/regulamin`} 
        class="hover:text-magenta-accent transition-colors cursor-pointer block"
      >
        Regulamin sklepu
      </a>
    </div>
  </div>
</footer>
